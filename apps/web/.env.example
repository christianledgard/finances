# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# BetterAuth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret
BETTER_AUTH_BASE_URL=http://localhost:3000
# Comma-separated extra origins allowed to call the auth API (optional)
# TRUSTED_ORIGINS=http://localhost:3000

# MongoDB — same instance as the extractor
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=finances

# M2M token for extractor — must match API_KEY in apps/extractor/.env
EXTRACTOR_API_KEY=change-me-to-a-long-random-secret
EXTRACTOR_URL=http://localhost:8000

# Dashboard branding & targets
NEXT_PUBLIC_APP_NAME=Finances
NEXT_PUBLIC_SALARY_CAP=5000
