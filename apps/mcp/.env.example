# Public URL where this MCP service is reachable (must match Google OAuth redirect config).
# Local dev: http://localhost:9000
# Production: https://finances-mcp.your-domain.com
PUBLIC_URL=http://localhost:9000

# Google OAuth 2.0 Web client (separate from the web dashboard client).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Extractor API (server-to-server). On Railway use the internal URL.
EXTRACTOR_URL=http://localhost:8000
EXTRACTOR_API_KEY=

# Signs MCP access tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SIGNING_KEY=

# Optional: encrypt OAuth tokens at rest (python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())").
# Without this, tokens live in memory only and are lost on restart.
STORAGE_ENCRYPTION_KEY=

# HTTP port (Railway sets PORT automatically).
PORT=9000
